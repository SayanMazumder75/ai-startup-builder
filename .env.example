# ================================
# AI Startup Builder - Environment
# ================================

# 🔑 Groq API Key (get free key from https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# 🌐 Server Configuration
PORT=5000
NODE_ENV=development

# 🔗 Client URL (for CORS)
CLIENT_URL=https://ai-startup-builder-omega.vercel.app ✅

# 🔐 JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ================================
# GROQ MODEL OPTIONS (pick one)
# ================================
# llama-3.3-70b-versatile   ← RECOMMENDED: best quality  (default)
# llama-3.1-8b-instant      ← fastest, lower quality
# mixtral-8x7b-32768        ← good balance, long context
# gemma2-9b-it              ← Google Gemma 2

GROQ_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=4000
